{
  "name": "abcd-mall-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm run install:fe && npm run install:be",
    "install:fe": "cd FRONTEND && pnpm install",
    "install:be": "cd BACKEND && dotnet restore",
    "dev:fe": "cd FRONTEND && pnpm dev",
    "dev:be": "cd BACKEND/ABCDMall.WebAPI && dotnet watch run",
    "dev": "concurrently \"npm run dev:be\" \"npm run dev:fe\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}