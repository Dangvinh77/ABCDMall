{
  "name": "abcd-mall-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm run install:fe && npm run install:be",
    "install:fe": "cd FRONTEND && pnpm install",
    "install:be": "cd BACKEND && dotnet restore",
    "dev:fe": "cd FRONTEND && pnpm dev",
    "dev:be": "cd BACKEND/ABCDMall.WebAPI && dotnet watch run",
    "dev": "concurrently \"npm run dev:be\" \"npm run dev:fe\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
