{
  "ConnectionStrings": {
    "ABCDMallConnection": "Server=<server_name>;Database=ABCDMall;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "AutoMapper": {
    "LicenseKey": "your-local-license-key"
  },
  "Jwt": {
    "Key": "your-super-secret-key-with-at-least-32-characters",
    "Issuer": "ABCDMall",
    "Audience": "ABCDMall.Frontend",
    "ExpireMinutes": 60
  },
  "EmailSettings": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "FromEmail": "",
    "FromName": "ABCDMall",
    "UserName": "",
    "Password": ""
  },
  "StripeSettings": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "FrontendBaseUrl": "http://localhost:5173"
  },
  "PayPalSettings": {
    "ClientId": "",
    "ClientSecret": "",
    "BaseUrl": "https://api-m.sandbox.paypal.com",
    "WebhookId": "",
    "ReturnUrl": "http://localhost:5173/movies/payment/success",
    "CancelUrl": "http://localhost:5173/movies/payment/cancel",
    "Currency": "USD"
  },
  "DatabaseStartup": {
    "ResetMoviesDatabase": false,
    "SeedMoviesData": true,
    "ResetFoodCourtDatabase": false,
    "SeedFoodCourtData": true,
    "ResetUsersDatabase": false,
    "SeedUsersData": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
