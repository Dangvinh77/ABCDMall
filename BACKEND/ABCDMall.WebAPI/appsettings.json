{
  "ConnectionStrings": {
    "ABCDMallConnection": "Server=<server_name>;Database=ABCDMall;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "AutoMapper": {
    "LicenseKey": "your-local-license-key"
  },
  "Jwt": {
    "Key": "your-super-secret-key-with-at-least-32-characters",
    "Issuer": "ABCDMall",
    "Audience": "ABCDMall.Frontend",
    "ExpireMinutes": 60
  },
  "EmailSettings": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "FromEmail": "",
    "FromName": "ABCDMall",
    "UserName": "",
    "Password": ""
  },
  "DatabaseStartup": {
    "ResetMoviesDatabase": false,
    "SeedMoviesData": true,
    "ResetFoodCourtDatabase": false,
    "SeedFoodCourtData": true,
    "ResetUsersDatabase": false,
    "SeedUsersData": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
